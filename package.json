  "description": "Production-grade TypeScript e-commerce REST API",
  "main": "dist/index.js",
  "type": "module",
  "scripts": {
    "dev": "tsx watch --tsconfig tsconfig.json index.ts",
    "build": "tsc && tsc-alias",

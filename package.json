    "@types/morgan": "^1.9.9",
    "@types/multer": "^1.4.12",
    "@types/node": "^22.10.2",
    "@types/nodemailer": "^6.4.17",
    "@types/pdfkit": "^0.13.6",
    "@types/qrcode": "^1.5.5",
    "@types/supertest": "^6.0.2",
